<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <div class="col-8 offset-2">
    <h3>Edit Listing</h3>
    <br /> 
    <form method="POST" action="/listings/<%=listing._id%>?_method=PUT">
        <div class="mb-3">
            <lable for="title" class="form-lable">Title</lable>
        <input name="listing[title]" value="<%=listing.title%>" type="text" class="form-control">
        </div>
        <div class="mb-3">
            <lable for="description" class="form-lable">Description</lable>
        <textarea name="listing[description]" class="form-control"><%=listing.description%></textarea>
        </div>
        <div class="mb-3">
            <lable for="image" class="form-lable">Image</lable>
        <input name="listing[image][url]" value="<%=listing.image.url%>" type="text" class="form-control">
        </div>
        <div class="row">
        <div class="mb-3 col-md-4">
            <lable for="price" class="form-lable">Price</lable>
        <input name="listing[price]" value="<%=listing.price%>" type="number" class="form-control">
        </div>
        <div class="mb-3 col-md-8">
            <lable for="country" class="form-lable">Country</lable>
        <input name="listing[country]" value="<%=listing.country%>" type="text" class="form-control">
        </div>
        </div>
        <div class="mb-3">
            <lable for="location" class="form-lable">Location</lable>
        <input name="listing[location]" value="<%=listing.location%>" type="text" class="form-control">
        </div>

            <button class="btn btn-dark add-btn mt-3">Edit</button>
        
    </form>
</div>
</div>
